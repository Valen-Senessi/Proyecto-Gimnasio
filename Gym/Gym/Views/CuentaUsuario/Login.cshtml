@model Gym.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Core Fitness - Acceso</title>
    <title>Core Fitness - Acceso</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-variant": "#dbe4e3",
                        "secondary-container": "#5ef6e6",
                        "outline-variant": "#b9cac9",
                        "on-secondary-container": "#006f66",
                        "tertiary": "#0c6780",
                        "primary": "#006a6a",
                        "on-primary": "#ffffff",
                        "surface-container-low": "#ecf5f4",
                        "on-background": "#151d1d",
                        "on-error": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed-variant": "#005049",
                        "on-surface-variant": "#3a4a49",
                        "surface-container": "#e7f0ef",
                        "on-primary-fixed-variant": "#004f4f",
                        "on-primary-fixed": "#002020",
                        "surface-container-high": "#e1eae9",
                        "background": "#f2fbfa",
                        "surface-container-highest": "#dbe4e3",
                        "tertiary-container": "#c2ecff",
                        "primary-fixed": "#00fbfb",
                        "on-tertiary-fixed": "#001f29",
                        "primary-fixed-dim": "#00dddd",
                        "error": "#ba1a1a",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#00dddd",
                        "inverse-on-surface": "#eaf3f2",
                        "on-secondary": "#ffffff",
                        "surface-bright": "#f2fbfa",
                        "secondary-fixed": "#61f9e9",
                        "secondary-fixed-dim": "#3adccc",
                        "secondary": "#006a62",
                        "on-error-container": "#93000a",
                        "outline": "#6a7a7a",
                        "on-secondary-fixed": "#00201d",
                        "on-tertiary-fixed-variant": "#004d62",
                        "inverse-surface": "#293232",
                        "on-tertiary-container": "#1c6f89",
                        "tertiary-fixed": "#baeaff",
                        "surface-dim": "#d3dcdb",
                        "surface": "#f2fbfa",
                        "on-surface": "#151d1d",
                        "primary-container": "#00ffff",
                        "surface-tint": "#006a6a",
                        "tertiary-fixed-dim": "#89d0ed",
                        "surface-container-lowest": "#ffffff",
                        "on-primary-container": "#007272"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "xl": "4rem",
                        "gutter": "24px",
                        "sm": "1rem",
                        "margin": "32px",
                        "md": "1.5rem",
                        "xs": "0.5rem",
                        "lg": "2.5rem",
                        "base": "4px"
                    },
                    "fontFamily": {
                        "headline-lg": ["Montserrat"],
                        "label-md": ["Inter"],
                        "headline-md": ["Montserrat"],
                        "headline-lg-mobile": ["Montserrat"],
                        "body-md": ["Inter"],
                        "display-lg": ["Montserrat"],
                        "body-lg": ["Inter"],
                        "label-sm": ["Inter"]
                    },
                    "fontSize": {
                        "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "500"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "headline-lg-mobile": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "label-sm": ["12px", {"lineHeight": "16px", "fontWeight": "600"}]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid #E2E8F0;
        }
        .bg-primary-gradient {
            background: linear-gradient(135deg, #40E0D0 0%, #00FFFF 100%);
        }
        .neon-glow {
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);
        }
        .input-focus-effect:focus {
            background-color: white;
            border-color: #00ffff;
            box-shadow: 0 0 0 2px rgba(0, 255, 255, 0.1);
            outline: none;
        }
        .field-validation-error {
            color: #ba1a1a;
            font-size: 12px;
            display: block;
            margin-top: 4px;
            margin-left: 4px;
        }
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0 0 12px 0;
        }
        .validation-summary-errors li {
            color: #ba1a1a;
            background: #ffdad6;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 6px;
        }
        input.input-validation-error {
            border-color: #ba1a1a !important;
        }
    </style>
</head>
<body class="bg-surface font-body-md text-on-surface selection:bg-primary-container selection:text-on-primary-container min-h-screen flex flex-col">

    <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-primary-container/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-tertiary-container/30 rounded-full blur-[100px]"></div>
    </div>

    <main class="relative z-10 flex-grow flex items-center justify-center p-sm md:p-lg">
        <div class="w-full max-w-[480px] space-y-md">
            <div class="text-center space-y-xs animate-in fade-in slide-in-from-bottom-4 duration-700">
                <div class="inline-flex items-center justify-center p-xs bg-primary-container rounded-xl shadow-sm mb-xs">
                    <span class="material-symbols-outlined text-[40px] text-on-primary-container" style="font-variation-settings: 'FILL' 1;">fitness_center</span>
                </div>
                <h1 class="font-headline-lg-mobile md:font-headline-lg text-primary tracking-tight">CORE FITNESS</h1>
                <h2 class="font-headline-md text-on-background">¡Bienvenido de nuevo!</h2>
                <p class="text-on-surface-variant font-body-md opacity-80">Gestión de alto rendimiento para tu centro.</p>
            </div>

            <div class="glass-card rounded-[24px] p-gutter shadow-sm border-t-[4px] border-tertiary-fixed animate-in fade-in zoom-in-95 duration-500 delay-200">

                <form asp-controller="CuentaUsuario" asp-action="Login" method="post" class="space-y-md">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                    <!-- DNI Input -->
                    <div class="space-y-xs">
                        <label class="block font-label-sm text-on-surface-variant ml-1" asp-for="DNI">DNI (Obligatorio)</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">badge</span>
                            <input asp-for="DNI" class="w-full pl-[52px] pr-md py-md bg-surface-container-low border-transparent border-2 rounded-xl font-body-md input-focus-effect transition-all placeholder:opacity-50" placeholder="Ej: 12.345.678" type="text" autocomplete="username">
                        </div>
                        <span asp-validation-for="DNI"></span>
                    </div>

                    <!-- Password Input -->
                    <div class="space-y-xs" id="password-group">
                        <div class="flex justify-between items-end ml-1">
                            <label class="block font-label-sm text-on-surface-variant" asp-for="UsuPsw">Contraseña</label>
                        </div>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">lock</span>
                            <input asp-for="UsuPsw" class="w-full pl-[52px] pr-[52px] py-md bg-surface-container-low border-transparent border-2 rounded-xl font-body-md input-focus-effect transition-all placeholder:opacity-50" placeholder="••••••••" type="password" autocomplete="current-password" id="password">
                            <button class="absolute right-md top-1/2 -translate-y-1/2 text-outline hover:text-on-surface transition-colors" onclick="togglePassword()" type="button">
                                <span class="material-symbols-outlined" id="eye-icon">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="UsuPsw"></span>
                    </div>

                    <!-- Actions -->
                    <div class="pt-sm space-y-md">
                        <button class="w-full py-md rounded-full bg-primary-gradient text-on-primary font-headline-md shadow-md neon-glow hover:scale-[1.02] active:scale-[0.98] transition-all duration-300" type="submit">
                            Ingresar
                        </button>
                        <div class="flex items-center justify-center">
                            <a class="font-label-sm text-tertiary hover:text-primary transition-colors hover:underline underline-offset-4" href="#">¿Olvidaste tu contraseña?</a>
                        </div>
                    </div>
                </form>
            </div>

            <footer class="flex flex-col md:flex-row items-center justify-center gap-md opacity-60">
                <p class="font-label-sm text-on-surface-variant">© 2026 Core Fitness Management.</p>
                <div class="flex gap-sm">
                    <a class="font-label-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Privacidad</a>
                    <a class="font-label-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Términos</a>
                    <a class="font-label-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Soporte</a>
                </div>
            </footer>
        </div>
    </main>

    <div class="hidden lg:block fixed top-1/2 right-[5%] -translate-y-1/2 w-[35vw] h-[60vh] opacity-80 pointer-events-none">
        <div class="relative w-full h-full rounded-[40px] overflow-hidden shadow-2xl border-[8px] border-white/20">
            <div class="w-full h-full bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBw8B8c_DS0C5pzCR1QFdSgBpfvCKwg7l9cH2gUBvPz8JVrByZpGiwwOCuylpU16kysUhhEtarX2Rj95yU0sk2_vfPb5W2RqIVFkqBNMLho3fWgrtsDxdJiBjtIQhGW1s4kf_hPHnfICXMoQmalLS4mKhQR2g1oghgy1zsju3f6Oj-_BDjU5nUSH2un9JNpWP8wR5bw49HImyOGb9j7Hcsxge-sQ86M3gU4bpWKUrImdLfSOUV00TByRMo75tofn8O2eRWMBxCeZvDC')"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('password');
            const icon = document.getElementById('eye-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>