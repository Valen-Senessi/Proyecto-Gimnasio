< script >
        const dniInput = document.getElementById('dni-input');
const statusCard = document.getElementById('member-status-card');
const statusBadge = document.getElementById('status-badge');
const statusIcon = document.getElementById('status-icon');
const statusIconContainer = document.getElementById('status-icon-container');
const paymentTitle = document.getElementById('payment-status-title');
const paymentDesc = document.getElementById('payment-status-desc');
const alertBox = document.getElementById('payment-alert');
const memberName = document.getElementById('member-name');
const memberPlan = document.getElementById('member-plan');

function press(num)
{
    if (dniInput.value.length < 8)
    {
        dniInput.value += num;
    }
}

function clearDNI()
{
    dniInput.value = '';
    resetView();
}

function resetView()
{
    statusCard.classList.add('opacity-50', 'grayscale', 'pointer-events-none');
    statusBadge.innerText = 'ESPERANDO DNI';
    statusBadge.className = 'px-3 py-1 rounded-full text-[10px] font-bold tracking-widest bg-outline-variant text-on-surface-variant';
    alertBox.className = 'flex-1 p-6 rounded-2xl bg-surface-container-low border border-outline-variant flex flex-col items-center justify-center text-center';
    statusIconContainer.className = 'w-16 h-16 rounded-full bg-surface-variant flex items-center justify-center mb-4 transition-transform duration-500';
    statusIcon.innerText = 'pending';
    paymentTitle.innerText = 'Sin Información';
    paymentDesc.innerText = 'Ingrese un número de documento para verificar el estado de cuenta.';
    memberName.innerText = '--- ---';
    memberPlan.innerText = 'Membresía: ---';
}

function validateDNI()
{
    const dni = dniInput.value;
    if (dni.length < 5) return;

    // Simple mock logic for demonstration
    statusCard.classList.remove('opacity-50', 'grayscale', 'pointer-events-none');

    // Randomly simulate success or pending
    const isPaid = Math.random() > 0.3;

    if (isPaid)
    {
        showPaidState();
    }
    else
    {
        showPendingState();
    }
}

function showPaidState()
{
    statusBadge.innerText = 'AL DÍA';
    statusBadge.className = 'px-3 py-1 rounded-full text-[10px] font-bold tracking-widest bg-primary-container text-on-primary-container';
    alertBox.className = 'flex-1 p-6 rounded-2xl bg-primary-container/10 border border-primary/20 flex flex-col items-center justify-center text-center';
    statusIconContainer.className = 'w-20 h-20 rounded-full bg-primary text-white flex items-center justify-center mb-4 scale-110 shadow-lg shadow-primary/20 transition-all';
    statusIcon.innerText = 'check_circle';
    paymentTitle.innerText = 'Acceso Autorizado';
    paymentTitle.className = 'font-headline-md mb-2 text-primary';
    paymentDesc.innerText = 'El socio tiene su cuota al día. Vence en 15 días.';
    memberName.innerText = 'Martin Rodriguez';
    memberPlan.innerText = 'Membresía: Plan Premium Plus';
}

function showPendingState()
{
    statusBadge.innerText = 'PENDIENTE';
    statusBadge.className = 'px-3 py-1 rounded-full text-[10px] font-bold tracking-widest bg-error-container text-on-error-container';
    alertBox.className = 'flex-1 p-6 rounded-2xl bg-error-container/10 border border-error/20 flex flex-col items-center justify-center text-center';
    statusIconContainer.className = 'w-20 h-20 rounded-full bg-error text-white flex items-center justify-center mb-4 scale-110 shadow-lg shadow-error/20 transition-all';
    statusIcon.innerText = 'warning';
    paymentTitle.innerText = 'Pago Pendiente';
    paymentTitle.className = 'font-headline-md mb-2 text-error';
    paymentDesc.innerText = 'La cuota venció el día 05/10. Debe regularizar su situación.';
    memberName.innerText = 'Julian Perez';
    memberPlan.innerText = 'Membresía: Pase Diario';
}
    </ script >






