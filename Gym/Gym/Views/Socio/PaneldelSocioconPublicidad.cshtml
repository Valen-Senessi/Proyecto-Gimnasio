<body class="bg-background text-on-surface font-body-md min-h-screen pb-32">
    <!-- TopAppBar -->
    <header class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/30 shadow-sm h-16">
        <div class="flex items-center justify-between px-gutter h-16 max-w-full mx-auto">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-2xl" data-icon="fitness_center">fitness_center</span>
                <h1 class="font-headline-md text-headline-md font-bold tracking-tighter text-primary">CORE FITNESS</h1>
            </div>
            <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors active:scale-95">
                <span class="material-symbols-outlined text-on-surface-variant" data-icon="notifications">notifications</span>
            </button>
        </div>
    </header>
    <main class="pt-20 px-4 md:px-margin max-w-5xl mx-auto space-y-6">
        <!-- Welcome Section -->
        <section class="py-4">
            <h2 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-on-surface">Hola, Valen! 👋</h2>
            <p class="text-on-surface-variant font-body-md mt-1">Listo para superar tus límites hoy?</p>
        </section>
        <!-- Live Capacity Card -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-[24px] p-6 shadow-[0px_4px_20px_rgba(0,0,0,0.04)] relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-full h-1 bg-[#87CEEB]"></div>
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h3 class="font-headline-md text-lg text-on-surface mb-1">Capacidad en vivo</h3>
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-sm" data-icon="location_on">location_on</span>
                            <span class="text-label-md font-label-md text-on-surface-variant">Sede Centro</span>
                        </div>
                    </div>
                    <div class="bg-secondary-container/20 px-3 py-1 rounded-full flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-secondary animate-pulse"></div>
                        <span class="text-label-sm font-label-sm text-secondary">LIVE</span>
                    </div>
                </div>
                <div class="space-y-4">
                    <!-- Dynamic Progress Bar -->
                    <div class="w-full h-4 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-secondary to-primary-container w-[65%] rounded-full neon-glow transition-all duration-1000 ease-out" style="width: 62.7559%;"></div>
                    </div>

                </div>
            </div>
            <!-- Quick Stats Bento Item -->
            <div class="bg-surface-container-lowest border border-outline-variant rounded-[24px] p-6 shadow-[0px_4px_20px_rgba(0,0,0,0.04)] flex flex-col justify-between">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 rounded-2xl bg-tertiary-container/30 flex items-center justify-center text-tertiary">
                        <span class="material-symbols-outlined" data-icon="timer">timer</span>
                    </div>
                    <div>
                        <p class="text-label-sm font-label-sm text-on-surface-variant">Racha de Entrenamiento</p>
                        <p class="text-headline-md font-headline-md">12 Días</p>
                    </div>
                </div>
                <div class="border-t border-outline-variant/30 pt-4">
                    <div class="flex justify-between items-center text-label-md font-label-md mb-2">
                        <span class="">Meta semanal</span>
                        <span class="text-primary">4 / 5 días</span>
                    </div>
                    <div class="w-full h-2 bg-surface-container-high rounded-full">
                        <div class="h-full bg-tertiary w-[80%] rounded-full"></div>
                    </div>
                </div>
            </div>
        </section>
        <!-- My Workouts Section -->
        <section class="py-2">
            <div class="relative overflow-hidden rounded-[24px] p-6 bg-gradient-to-br from-secondary to-tertiary text-white shadow-lg group cursor-pointer">
                <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-primary-container/20 rounded-full blur-3xl group-hover:scale-110 transition-transform duration-500"></div>
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div class="space-y-2">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary-fixed" data-icon="star">star</span>
                            <span class="font-label-sm text-label-sm uppercase tracking-widest text-primary-fixed">Oferta Exclusiva</span>
                        </div>
                        <h3 class="font-headline-md text-xl md:text-2xl">Potencia tu Rendimiento</h3>
                        <p class="text-body-md text-white/90 max-w-md">Obtén un 20% de descuento en nuestra nueva línea de proteínas CORE-ISO. Solo para miembros activos.</p>
                    </div>
                    <button class="bg-surface-container-lowest text-secondary px-6 py-3 rounded-xl font-bold text-label-md hover:bg-primary-container transition-colors active:scale-95 whitespace-nowrap">
                        VER TIENDA
                    </button>
                </div>
            </div>
        </section><section class="space-y-4">
            <div class="flex justify-between items-center">
                <h3 class="font-headline-md text-headline-md text-on-surface">Mis Rutinas</h3>
                <button class="text-primary font-label-md flex items-center gap-1 hover:underline">
                    Ver todas <span class="material-symbols-outlined text-sm" data-icon="arrow_forward">arrow_forward</span>
                </button>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Workout Card -->
                <div class="group bg-surface-container-lowest border border-outline-variant rounded-[24px] overflow-hidden shadow-[0px_4px_20px_rgba(0,0,0,0.04)] flex flex-col">
                    <div class="h-48 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                        <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="A cinematic, high-contrast shot of a modern industrial gym interior with turquoise and cyan accent lighting. A focused athlete stands in the distance among pristine weight racks and chrome plates. The atmosphere is energetic and tech-forward, with cool blue tones and heavy cinematic atmosphere." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAZA3kZeatWWxjdm6LF6w-eeEEJBC9V6WjiKRQBgYXenFNyk2-477jQlgVxfEUxUnZNpn_vxkRVU-xrUU00qAL7BeaMNG30d-fPelfzR6Nti1gzHa0v3CjMaA8AK9H8Ip51TbPuPUf3PYoU1XehTMr52iVEkHZd43v4UilBWt5vlhniSN0vw5zUBMjj2kzG9qV2ocGonemuxIiVhX8qNggBLYSr-VgYCBCfG3ubuEq03EnpB3rXto9U-W441SK1chflU2nPMhrnlnZ5">
                        <div class="absolute bottom-4 left-6 z-20">
                            <span class="bg-primary-container/90 text-on-primary-container px-3 py-1 rounded-full text-label-sm font-label-sm backdrop-blur-sm">Día A</span>
                        </div>
                    </div>
                    <div class="p-6 flex-grow flex flex-col justify-between">
                        <div>
                            <h4 class="font-headline-md text-xl text-on-surface mb-2">Hipertrofia - Pecho y Tríceps</h4>
                            <p class="text-body-md text-on-surface-variant mb-4">Enfoque en desarrollo de masa muscular. Incluye press de banca, aperturas y extensiones de polea.</p>
                            <div class="flex flex-wrap gap-2 mb-6">
                                <span class="px-3 py-1 rounded-full bg-surface-container-high text-on-surface-variant text-label-sm font-label-sm">60 min</span>
                                <span class="px-3 py-1 rounded-full bg-surface-container-high text-on-surface-variant text-label-sm font-label-sm">Intermedio</span>
                                <span class="px-3 py-1 rounded-full bg-surface-container-high text-on-surface-variant text-label-sm font-label-sm">8 Ejercicios</span>
                            </div>
                        </div>
                        <button class="w-full bg-gradient-to-r from-[#40E0D0] to-[#00FFFF] text-on-primary py-4 rounded-xl font-bold tracking-wide shadow-lg hover:shadow-[#00FFFF]/30 active:scale-95 transition-all duration-200 uppercase">
                            Empezar entrenamiento
                        </button>
                    </div>
                </div>
                <!-- Secondary Workout Bento/Stack -->
                <div class="space-y-4">
                    <div class="bg-surface-container-lowest border border-outline-variant rounded-[24px] p-4 flex items-center gap-4 hover:bg-surface-container-low transition-colors cursor-pointer group">
                        <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">
