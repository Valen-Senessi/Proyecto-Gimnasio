    <!-- BottomNavBar -->
    <nav class="fixed bottom-0 left-0 w-full h-20 bg-surface/80 backdrop-blur-xl border-t border-outline-variant/30 flex justify-around items-center px-4 pb-safe z-50 rounded-t-xl shadow-[0px_-4px_20px_rgba(0,0,0,0.04)]">
        <!-- Dashboard (Active) -->
        <a class="flex flex-col items-center justify-center text-primary bg-primary-container/20 rounded-xl px-4 py-1 transition-transform duration-200 active:scale-90" href="#">
            <span class="material-symbols-outlined" data-icon="dashboard" style="font-variation-settings: &quot;FILL&quot; 1;">dashboard</span>
            <span class="font-label-sm text-label-sm">MENÚ</span>
        </a>
        <!-- Workouts -->
        <a class="flex flex-col items-center justify-center text-on-surface-variant hover:text-primary transition-colors duration-200 active:scale-90" href="#">
            <span class="material-symbols-outlined" data-icon="exercise">exercise</span>
            <span class="font-label-sm text-label-sm">ENTRENAMIENTOS</span>
        </a>
        <!-- Schedule -->
        <a class="flex flex-col items-center justify-center text-on-surface-variant hover:text-primary transition-colors duration-200 active:scale-90" href="#">
            <span class="material-symbols-outlined" data-icon="calendar_month">calendar_month</span>
            <span class="font-label-sm text-label-sm">CALENDARIO</span>
        </a>
        <!-- Profile -->
        <a class="flex flex-col items-center justify-center text-on-surface-variant hover:text-primary transition-colors duration-200 active:scale-90" href="#">
            <span class="material-symbols-outlined" data-icon="person">person</span>
            <span class="font-label-sm text-label-sm">PERFIL</span>
        </a>
    </nav>
    <script>
        // Simple micro-interaction for the progress bar
        document.addEventListener('DOMContentLoaded', () => {
            const bar = document.querySelector('.bg-gradient-to-r');
            // Mock dynamic update
            setInterval(() => {
                const variation = (Math.random() * 4) - 2;
                const currentWidth = parseFloat(bar.style.width || '65');
                const newWidth = Math.min(Math.max(currentWidth + variation, 60), 75);
                bar.style.width = newWidth + '%';
            }, 5000);
        });
    </script>


</body>
</html>