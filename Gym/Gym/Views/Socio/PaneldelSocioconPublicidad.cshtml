<!DOCTYPE html>
<html class="light" lang="es" style="">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>CORE FITNESS - Member Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .neon-glow {
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.4);
        }
        @@keyframes pulse-slow {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        .animate-pulse-slow {
            animation: pulse-slow 3s infinite ease-in-out;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-surface": "#151d1d",
                        "surface-container-low": "#ecf5f4",
                        "error": "#ba1a1a",
                        "inverse-on-surface": "#eaf3f2",
                        "on-background": "#151d1d",
                        "surface-container-lowest": "#ffffff",
                        "on-surface-variant": "#3a4a49",
                        "on-error-container": "#93000a",
                        "secondary-fixed": "#61f9e9",
                        "on-secondary": "#ffffff",
                        "surface-tint": "#006a6a",
                        "on-tertiary-container": "#1c6f89",
                        "secondary-container": "#5ef6e6",
                        "on-secondary-fixed-variant": "#005049",
                        "inverse-surface": "#293232",
                        "surface-variant": "#dbe4e3",
                        "on-primary-fixed-variant": "#004f4f",
                        "tertiary": "#0c6780",
                        "primary-fixed": "#00fbfb",
                        "on-primary": "#ffffff",
                        "tertiary-container": "#c2ecff",
                        "tertiary-fixed": "#baeaff",
                        "on-secondary-container": "#006f66",
                        "secondary-fixed-dim": "#3adccc",
                        "on-primary-container": "#007272",
                        "surface-container-high": "#e1eae9",
                        "surface": "#f2fbfa",
                        "background": "#f2fbfa",
                        "secondary": "#006a62",
                        "on-primary-fixed": "#002020",
                        "surface-dim": "#d3dcdb",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#00dddd",
                        "outline-variant": "#b9cac9",
                        "surface-container": "#e7f0ef",
                        "primary": "#006a6a",
                        "on-tertiary-fixed-variant": "#004d62",
                        "surface-bright": "#f2fbfa",
                        "error-container": "#ffdad6",
                        "outline": "#6a7a7a",
                        "on-tertiary-fixed": "#001f29",
                        "surface-container-highest": "#dbe4e3",
                        "primary-container": "#00ffff",
                        "on-secondary-fixed": "#00201d",
                        "tertiary-fixed-dim": "#89d0ed",
                        "primary-fixed-dim": "#00dddd",
                        "on-error": "#ffffff"
