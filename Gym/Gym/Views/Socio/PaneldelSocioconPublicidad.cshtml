                        "sm": "1rem",
                        "gutter": "24px",
                        "margin": "32px",
                        "base": "4px",
                        "xs": "0.5rem",
                        "lg": "2.5rem",
                        "xl": "4rem",
                        "md": "1.5rem"
                    },
