                        </div>
                        <div class="flex-grow">
                            <h5 class="font-bold text-on-surface">Día B: Pierna y Core</h5>

                        </div>
                        <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors" data-icon="chevron_right">chevron_right</span>
                    </div>
                    <div class="bg-surface-container-lowest border border-outline-variant rounded-[24px] p-4 flex items-center gap-4 hover:bg-surface-container-low transition-colors cursor-pointer group">
                        <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">
                            <img class="w-full h-full object-cover" data-alt="Close up of a muscular back and shoulders of an athlete doing pull ups in a professional gym environment. Cyan and turquoise lighting, professional fitness photography style." src="https://lh3.googleusercontent.com/aida-public/AB6AXuADLnQVShKznYoEH2UDWAYdH2qtqNg2KpiTfqYJWTp4EfzHIn6hPXd09WsNwX8oNuxfDWE310L_45bvdTxGPXDBhJYJhqMQoXV1RwTCXz5BKCGNZkz-EyelwNxCNOth2GSOMbetupC5Yfdtkc_Glsw6QpXYV_23u6EorLx5g9Q7CB2-3EYzTp2wOddX5IY1fdfm1m_RI_LDz9jks2FKl1kM9F1SqLTxUpS8zxd6EsXCk5AkzH4iQdf866_RmS_XHS_1AACHk6D7r7dL">
                        </div>
                        <div class="flex-grow">
                            <h5 class="font-bold text-on-surface">Día C: Espalda y Bíceps</h5>

                        </div>
                        <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors" data-icon="chevron_right">chevron_right</span>
                    </div>
                    <!-- Promo/CTA Card -->
                    <div class="relative rounded-[24px] overflow-hidden h-32 flex items-center p-6 text-white">
                        <div class="absolute inset-0 bg-primary/90 mix-blend-multiply z-10"></div>
                        <img class="absolute inset-0 w-full h-full object-cover" data-alt="Dynamic shot of a gym class with multiple people moving in sync. The background is a clean, modern gym with high tech displays. Lighting is bright with blue tints." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDDZGymzpG7TuF5X6WcG8enyETfGOviU7sUuq-mnAZ2LzRXCFW5m8wovvLwQXFtdIswgTR4PTdbe6OTjDwH1vygRiSotXTyKxXr3LeInnkjgkD2oaRYtX5ui60PDRZM3Eb9ANI3dfksNJC6K6gQQidtqZWLBLgTHpKSSQmDgYTVZjWuy2yxc1_EtThdVAsvx5VtwgNJi0nLYSzZNxk-19V_1wkDy2qwSOwca1QNMKh9NnEtUSuwo5E1XIM_xt4NrMcbkJrzpx_OEyAb">
