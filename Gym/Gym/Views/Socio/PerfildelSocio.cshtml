    <script>
        // Micro-interaction for cards
        document.querySelectorAll('.glass-card').forEach(card => {
            card.addEventListener('touchstart', () => {
                card.style.transform = 'scale(0.98)';
            });
            card.addEventListener('touchend', () => {
                card.style.transform = 'scale(1)';
            });
        });

        // Pause carousel on touch
        const carousel = document.querySelector('.animate-carousel');
        let isPaused = false;

        document.querySelector('section.overflow-hidden').addEventListener('touchstart', () => {
            document.querySelectorAll('.animate-carousel').forEach(el => el.style.animationPlayState = 'paused');
        });
        document.querySelector('section.overflow-hidden').addEventListener('touchend', () => {
            document.querySelectorAll('.animate-carousel').forEach(el => el.style.animationPlayState = 'running');
        });
    </script>


</body>
</html>