                    <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 text-primary">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        <span class="font-label-md text-label-md uppercase">Vigente</span>
