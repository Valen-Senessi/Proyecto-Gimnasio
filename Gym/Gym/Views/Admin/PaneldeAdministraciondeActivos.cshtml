                <div class="glass-card p-gutter rounded-[24px] relative overflow-hidden h-[400px]">
                    <!-- Background Grid Lines -->
                    <div class="absolute inset-x-gutter inset-y-gutter flex flex-col justify-between opacity-10 pointer-events-none">
                        <div class="border-t border-outline w-full"></div>
                        <div class="border-t border-outline w-full"></div>
                        <div class="border-t border-outline w-full"></div>
                        <div class="border-t border-outline w-full"></div>
                        <div class="border-t border-outline w-full"></div>
                    </div>

                    <!-- Bar Chart Layout -->
                    <div class="relative h-full flex flex-col justify-end">
                        <svg class="absolute inset-0 w-full h-[300px] pointer-events-none z-10" viewBox="0 0 700 300" preserveAspectRatio="none">
                            <path d="M 50 165 L 150 105 L 250 45 L 350 120 L 450 75 L 550 15 L 650 180" fill="none" stroke="#00ffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-lg opacity-80"></path>
                            <circle cx="50" cy="165" r="4" fill="#00ffff"></circle>
                            <circle cx="150" cy="105" r="4" fill="#00ffff"></circle>
                            <circle cx="250" cy="45" r="4" fill="#00ffff"></circle>
                            <circle cx="350" cy="120" r="4" fill="#00ffff"></circle>
                            <circle cx="450" cy="75" r="4" fill="#00ffff"></circle>
                            <circle cx="550" cy="15" r="4" fill="#00ffff"></circle>
                            <circle cx="650" cy="180" r="4" fill="#00ffff"></circle>
                        </svg>
                        <div class="flex items-end justify-between h-[300px] px-8 gap-4">
                            <!-- Monday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[45%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-primary/60 h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-primary transition-colors">Lun</span>
                            </div>
                            <!-- Tuesday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[65%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-primary/80 h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-primary transition-colors">Mar</span>
                            </div>
                            <!-- Wednesday (Active/Peak) -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[85%] transition-all duration-500 hover:scale-y-105 origin-bottom shadow-lg shadow-primary/20">
                                    <div class="absolute bottom-0 left-0 w-full primary-gradient h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-primary">Mié</span>
                            </div>
                            <!-- Thursday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[60%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-primary/80 h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-primary transition-colors">Jue</span>
                            </div>
                            <!-- Friday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[75%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-primary/80 h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-primary transition-colors">Vie</span>
                            </div>
                            <!-- Saturday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[95%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-tertiary h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-tertiary transition-colors">Sáb</span>
                            </div>
                            <!-- Sunday -->
                            <div class="flex-1 flex flex-col items-center group cursor-pointer">
                                <div class="relative w-full max-w-[40px] bg-surface-container-highest rounded-t-xl overflow-hidden h-[40%] transition-all duration-500 hover:scale-y-105 origin-bottom">
                                    <div class="absolute bottom-0 left-0 w-full bg-primary/60 h-full"></div>
                                </div>
                                <span class="mt-4 text-xs font-bold text-on-surface-variant group-hover:text-primary transition-colors">Dom</span>
                            </div>
                        </div>
                    </div>

                    <!-- Tooltip Simulation -->
                    <div class="absolute top-[20%] left-[38%] glass-card p-3 rounded-xl border border-primary/20 shadow-xl pointer-events-none animate-pulse">
                        <p class="text-[10px] uppercase font-bold text-outline">Pico de Ocupación</p>
                        <p class="text-sm font-black text-on-surface">1,248 Usuarios <span class="text-[10px] text-primary font-bold">+12%</span></p>
                        <p class="text-[10px] text-on-surface-variant">Mié, 14:00 - 18:00</p>
                    </div>
                </div>
            </section>
        </div>
        <!-- Floating Quick Action Button -->
        <button class="fixed bottom-8 right-8 px-6 py-3 primary-gradient rounded-xl shadow-2xl flex items-center gap-2 text-white hover:scale-110 active:scale-95 transition-all z-50">
            <span class="material-symbols-outlined" data-icon="auto_awesome">auto_awesome</span>
            <span class="font-bold tracking-wide">Predecir con IA</span>
        </button>
    </main>
    <script>
        // Micro-interacción para el colapso de la barra lateral o animaciones de estado activo
        document.querySelectorAll('nav a').forEach(link => {
            link.addEventListener('click', function(e) {
                if(this.getAttribute('href') === '#') e.preventDefault();
            });
        });

        // Simulando algunas actualizaciones del tablero
        const systemStatus = document.querySelector('.animate-pulse');
        setInterval(() => {
            systemStatus.classList.toggle('opacity-50');
        }, 1500);
    </script>




</body>
</html>