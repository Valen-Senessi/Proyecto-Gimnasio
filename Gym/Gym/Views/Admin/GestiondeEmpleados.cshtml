    <!-- Simple Payment Interaction Script -->
    <script>
        function animatePay(btn) {
            const row = btn.closest('tr');
            const statusCell = row.querySelector('td:nth-child(4)');

            // Animation for the button
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[20px]" data-icon="sync">sync</span>';
            btn.classList.add('opacity-80', 'pointer-events-none');

            // Simulate processing
            setTimeout(() => {
                // Change status tag
                statusCell.innerHTML = `
                    <span class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full bg-secondary-container/20 text-secondary text-label-sm font-bold transition-all duration-500 scale-110">
                        <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                        Pagado
                    </span>
                `;

                // Reset and disable button
                btn.innerHTML = 'Pagado';
                btn.classList.remove('bg-gradient-to-r', 'from-[#40E0D0]', 'to-[#00FFFF]', 'text-on-primary', 'shadow-sm');
                btn.classList.add('bg-surface-container', 'text-on-surface-variant', 'opacity-50', 'cursor-not-allowed');

                // Toast notification (minimalist)
                showToast("Pago procesado con éxito");
            }, 1500);
        }

        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-10 left-1/2 -translate-x-1/2 bg-inverse-surface text-inverse-on-surface px-6 py-3 rounded-full font-label-md shadow-2xl z-[100] flex items-center gap-2 animate-bounce';
            toast.innerHTML = `<span class="material-symbols-outlined text-secondary" data-icon="check_circle">check_circle</span> ${message}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>




