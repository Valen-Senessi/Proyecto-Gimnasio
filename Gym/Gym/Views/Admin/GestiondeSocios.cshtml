                                <td class="px-gutter py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <button class="p-2 text-primary hover:bg-primary/10 rounded-full transition-colors flex items-center gap-1 text-[13px] font-bold">
                                            <span class="material-symbols-outlined text-[20px]">history_edu</span>
                                            <span class="hidden lg:inline">Historial</span>
                                        </button>
                                        <button class="p-2 text-on-surface-variant hover:bg-surface-variant/50 rounded-full transition-all">
                                            <span class="material-symbols-outlined text-[20px]">more_vert</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="px-gutter py-4 flex items-center justify-between bg-surface-container-lowest border-t border-outline-variant/20">
                    <span class="text-label-sm text-on-surface-variant">Mostrando 4 de 1.248 socios</span>
                    <div class="flex items-center gap-1">
                        <button class="p-2 rounded-lg hover:bg-surface-variant/20 disabled:opacity-30" disabled="">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        <button class="w-8 h-8 rounded-lg bg-primary text-on-primary font-bold text-xs">1</button>
                        <button class="w-8 h-8 rounded-lg hover:bg-surface-variant/20 text-on-surface-variant font-bold text-xs">2</button>
                        <button class="w-8 h-8 rounded-lg hover:bg-surface-variant/20 text-on-surface-variant font-bold text-xs">3</button>
                        <button class="p-2 rounded-lg hover:bg-surface-variant/20">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- Floating Quick View Panel (Simulated interaction) -->
        <div class="fixed right-margin bottom-margin w-80 glass-panel p-md rounded-[24px] shadow-xl border-primary/20 translate-y-[120%] transition-transform duration-500 ease-out z-50" id="quick-view">
            <div class="flex justify-between items-center mb-4">
                <h4 class="font-headline-md text-[18px] text-primary">Vista Rápida de Socio</h4>
                <button class="material-symbols-outlined text-on-surface-variant hover:text-error transition-colors" onclick="toggleQuickView()">close</button>
            </div>
            <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-full bg-secondary-container"></div>
                <div>
                    <p class="font-bold text-on-surface">Selecciona un socio</p>
                    <p class="text-xs text-on-surface-variant">Para ver historial</p>
                </div>
            </div>
            <div class="space-y-3">
                <div class="h-2 w-full bg-surface-container rounded-full overflow-hidden">
                    <div class="h-full bg-primary" style="width: 45%;"></div>
                </div>
                <p class="text-[11px] text-on-surface-variant">Meta de Asistencia: 45%</p>
                <button class="w-full py-2 bg-primary text-on-primary rounded-xl font-bold text-xs hover:opacity-90 transition-opacity">PERFIL COMPLETO</button>
            </div>
        </div>
    </main>
    <script>
        // Micro-interaction for quick view panel
        function toggleQuickView() {
            const panel = document.getElementById('quick-view');
            if (panel.classList.contains('translate-y-[120%]')) {
                panel.classList.remove('translate-y-[120%]');
                panel.classList.add('translate-y-0');
            } else {
                panel.classList.add('translate-y-[120%]');
                panel.classList.remove('translate-y-0');
            }
        }

        // Add event listeners to "Historial" buttons to show interaction
        document.querySelectorAll('button[title="Ver Historial de Entrenamiento"], td.px-gutter.py-4.text-right button.text-primary').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                toggleQuickView();

                // If it's a specific row, update the placeholder name in the snapshot
                const row = btn.closest('tr');
                if (row) {
                    const name = row.querySelector('.font-bold.text-on-surface').innerText;
                    const quickViewName = document.querySelector('#quick-view p.font-bold');
                    const quickViewImg = document.querySelector('#quick-view .w-12');
                    const rowImgSrc = row.querySelector('img').src;

                    quickViewName.innerText = name;
                    quickViewImg.innerHTML = `<img src="${rowImgSrc}" class="w-full h-full rounded-full object-cover">`;
                }
            });
        });

        // Search bar interaction
        const searchInput = document.querySelector('input[placeholder="Buscar socios..."]');
        searchInput.addEventListener('focus', () => {
            searchInput.parentElement.classList.add('w-80');
            searchInput.parentElement.classList.remove('w-64');
        });
        searchInput.addEventListener('blur', () => {
            searchInput.parentElement.classList.add('w-64');
            searchInput.parentElement.classList.remove('w-80');
        });
    </script>


</body>
</html>