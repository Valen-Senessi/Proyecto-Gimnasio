    </main>
    <script>
        // Micro-interactions for live occupancy bars
        document.querySelectorAll('.neon-glow').forEach(bar => {
            const finalWidth = bar.style.width;
            bar.style.width = '0%';
            setTimeout(() => {
                bar.style.transition = 'width 1.5s cubic-bezier(0.2, 0.8, 0.2, 1)';
                bar.style.width = finalWidth;
            }, 300);
        });

        // Search highlight interaction
        const searchInput = document.querySelector('input[type="text"]');
        if(searchInput) {
            searchInput.addEventListener('focus', () => {
                searchInput.parentElement.classList.add('scale-105');
            });
            searchInput.addEventListener('blur', () => {
                searchInput.parentElement.classList.remove('scale-105');
            });
        }
    </script>




